# ==========================================
# MADECC Group Portal - Environment Variables Configuration
# Copy this file to '.env' and fill in the values for local development.
# ==========================================

# Database Connection (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]
# In production, Neon or Supabase PostgreSQL URLs with SSL are supported.
DATABASE_URL=postgresql://your_db_user:your_db_password@your_db_host:5432/your_db_name?sslmode=require

# Google Gemini AI API Key
# Required for Virtual Assistant Chat and AI Document Workflows.
GEMINI_API_KEY=your_gemini_api_key_here

# Secret used to sign and verify CSRF protection tokens (Optional - defaults to a secure dynamic server secret if not set)
CSRF_SECRET=your_cryptographically_secure_csrf_secret_here

# Node Environment
# Values: 'development', 'production'
NODE_ENV=development

# Server Port
# Note: In the AI Studio workspace, port 3000 is required.
PORT=3000

# Application URL (for self-referential links, e.g. emails)
# Note: In the AI Studio workspace, this is automatically routed.
APP_URL=http://localhost:3000

# SMTP Mail Server Credentials (Optional, used for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email@gmail.com
SMTP_PASS=your_smtp_app_password

# Production File Storage Services (Optional - Falls back to safe container disk storage)
# Option A: Supabase Storage configuration
SUPABASE_URL=https://your_supabase_project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_BUCKET=your_supabase_bucket_name

# Option B: Cloudinary CDN configuration
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
