// prisma/schema.prisma

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Recommended for migrations bypassing connection poolers
}

generator client {
  provider = "prisma-client-js"
}

/// 1. Users Table (Admin, Staff, Clients)
model User {
  id        Int        @id @default(autoincrement())
  uid       String     @unique // Firebase Auth UID Link
  email     String     @unique
  name      String
  role      String     @default("client") // admin, staff, client
  createdAt DateTime   @default(now()) @map("created_at")
  blogPosts BlogPost[]

  @@map("users")
}

/// 2. Categories Table
model Category {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String    @unique
  projects Project[]

  @@map("categories")
}

/// 3. Projects Table
model Project {
  id          Int               @id @default(autoincrement())
  title       String
  description String            @db.Text
  budget      Decimal?          @db.Decimal(12, 2)
  location    String
  startDate   DateTime?         @map("start_date")
  endDate     DateTime?         @map("end_date")
  status      String            @default("planning") // planning, in-progress, completed, on-hold
  categoryId  Int?              @map("category_id")
  category    Category?         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  image       String
  createdAt   DateTime          @default(now()) @map("created_at")
  progress    ProjectProgress[]

  @@map("projects")
}

/// 4. Project Progress Table (Milestones)
model ProjectProgress {
  id            Int      @id @default(autoincrement())
  projectId     Int      @map("project_id")
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneName String   @map("milestone_name")
  percentage    Int      @default(0)
  date          DateTime @default(now())
  description   String   @db.Text
  status        String   @default("pending") // pending, active, completed

  @@map("project_progress")
}

/// 5. Blog Posts Table
model BlogPost {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.Text
  authorId    Int?     @map("author_id")
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  publishedAt DateTime @default(now()) @map("published_at")
  image       String
  summary     String   @db.Text
  category    String

  @@map("blog_posts")
}

/// 6. Reviews Table (with Staff moderation)
model Review {
  id          Int       @id @default(autoincrement())
  authorName  String    @map("author_name")
  rating      Int
  text        String    @db.Text
  approved    Boolean   @default(false)
  approvedAt  DateTime? @map("approved_at")
  projectName String?   @map("project_name")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("reviews")
}

/// 7. Appointments Table
model Appointment {
  id              Int      @id @default(autoincrement())
  clientName      String   @map("client_name")
  clientEmail     String   @map("client_email")
  serviceName     String   @map("service_name")
  appointmentDate DateTime @map("appointment_date")
  status          String   @default("pending") // pending, confirmed, cancelled, completed
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("appointments")
}

/// 8. Contact Messages Table
model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  status    String   @default("new") // new, read, replied
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

/// 9. Newsletter Subscribers Table
model NewsletterSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  status    String   @default("subscribed") // subscribed, unsubscribed
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscribers")
}

/// 10. Services Table
model Service {
  id          Int     @id @default(autoincrement())
  name        String
  description String  @db.Text
  icon        String
  priceRange  String? @map("price_range")
  details     String? @db.Text // Stringified features array

  @@map("services")
}

/// 11. Gallery Items Table
model GalleryItem {
  id        Int      @id @default(autoincrement())
  title     String
  imageUrl  String   @map("image_url")
  category  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("gallery_items")
}

/// 12. Hero Banners Table
model HeroBanner {
  id           Int     @id @default(autoincrement())
  title        String
  subtitle     String?
  imageUrl     String  @map("image_url")
  displayOrder Int     @default(0) @map("display_order")
  active       Boolean @default(true)

  @@map("hero_banners")
}

/// 13. Company Documents Table
model CompanyDocument {
  id        Int      @id @default(autoincrement())
  title     String
  fileUrl   String   @map("file_url")
  docType   String   @map("doc_type") // safety_policy, certification, quote_template, general
  version   String   @default("1.0")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("company_documents")
}

/// 14. Audit Logs Table
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    String?  @map("user_id") // Firebase Auth UID
  userEmail String?  @map("user_email")
  action    String // 'CREATE_PROJECT', 'APPROVE_REVIEW', etc.
  details   String   @db.Text
  timestamp DateTime @default(now())

  @@map("audit_logs")
}
